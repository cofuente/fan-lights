#!/usr/bin/env python3
"""fanlight — Framework fan LED controller."""

import os
import sys
import time
import signal
import subprocess

# Resolve the fan-lights repo directory. In order of preference:
#   1. $FAN_LIGHTS_DIR env var (explicit override)
#   2. The directory containing this script, if daemon.py is a sibling
#      (works when running straight from a clone: `./fanlight`)
#   3. ~/Repos/fan-lights (the documented install location, used when
#      this script has been copied to ~/.local/bin/fanlight)
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
FAN_LIGHTS_DIR = (
    os.environ.get("FAN_LIGHTS_DIR")
    or (_SCRIPT_DIR if os.path.exists(os.path.join(_SCRIPT_DIR, "daemon.py")) else None)
    or os.path.expanduser("~/Repos/fan-lights")
)
OPENRGB_BIN   = "/usr/bin/openrgb"
DAEMON        = os.path.join(FAN_LIGHTS_DIR, "daemon.py")

# ─── Colours ──────────────────────────────────────────────────────────────────
CYAN   = "\033[0;36m"
GREEN  = "\033[0;32m"
YELLOW = "\033[0;33m"
RED    = "\033[0;31m"
BOLD   = "\033[1m"
RESET  = "\033[0m"

def ok(msg):   print(f"{GREEN}✓{RESET}  {msg}")
def warn(msg): print(f"{YELLOW}!{RESET}  {msg}")
def err(msg):  print(f"{RED}✗{RESET}  {msg}")

# ─── Pattern discovery ────────────────────────────────────────────────────────

def discover_patterns():
    sys.path.insert(0, FAN_LIGHTS_DIR)
    try:
        from patterns import discover
        return discover()
    except Exception as e:
        err(f"Could not load patterns from {FAN_LIGHTS_DIR}: {e}")
        sys.exit(1)

# ─── Process management ───────────────────────────────────────────────────────

def start_pattern(choice):
    """Run daemon.py in the background, inheriting the terminal for sudo-rs."""
    return subprocess.Popen(
        ["sudo", "-n", "python3", DAEMON, choice],
        cwd=FAN_LIGHTS_DIR,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
    )

def stop_pattern(proc):
    """Terminate daemon.py gracefully (its SIGTERM handler turns lights off)."""
    if proc is None or proc.poll() is not None:
        return
    try:
        proc.terminate()
        proc.wait(timeout=2)
    except subprocess.TimeoutExpired:
        proc.kill()

# ─── Input helper ─────────────────────────────────────────────────────────────

def get_choice(patterns, names):
    """Read and validate user input. Returns pattern string, 'gui', or 'quit'."""
    print(f"  {YELLOW}Tip:{RESET} enter comma-separated names to cycle, e.g. {CYAN}rainbow,fire{RESET}")
    print()
    while True:
        try:
            raw = input(f"{BOLD}>{RESET} ").strip().lower()
        except (KeyboardInterrupt, EOFError):
            print()
            return "quit"

        if not raw:
            continue
        if raw == "q":
            return "quit"
        if raw == "g":
            return "gui"

        if raw.isdigit():
            idx = int(raw) - 1
            if idx == len(names):           # "cycle all" option
                return ",".join(names)
            if 0 <= idx < len(names):
                return names[idx]
            warn("Number out of range — try again")
            continue

        tokens = [t.strip() for t in raw.split(",")]
        invalid = [t for t in tokens if t not in patterns]
        if invalid:
            warn(f"Unknown pattern(s): {', '.join(invalid)} — try again")
            continue

        return ",".join(tokens)

# ─── Menus ────────────────────────────────────────────────────────────────────

def main_menu(patterns):
    names = sorted(patterns.keys())
    print(f"\n{BOLD}Choose a pattern:{RESET}\n")
    for i, name in enumerate(names, 1):
        print(f"  {CYAN}{i}{RESET}. {name}")
    print(f"  {CYAN}{len(names) + 1}{RESET}. cycle all  (30s each)")
    print()
    print(f"  {CYAN}g{RESET}. open OpenRGB GUI")
    print(f"  {CYAN}q{RESET}. quit")
    print()
    return get_choice(patterns, names)

def running_menu(patterns, current):
    names  = sorted(patterns.keys())
    label  = f"cycling {current.replace(',', ' → ')}" if "," in current else current
    print(f"\n{GREEN}►{RESET} {BOLD}{label}{RESET}\n")
    print(f"{BOLD}Switch pattern:{RESET}\n")
    for i, name in enumerate(names, 1):
        active = f"{GREEN}●{RESET}" if name == current else " "
        print(f"  {active} {CYAN}{i}{RESET}. {name}")
    print(f"  {CYAN}{len(names) + 1}{RESET}. cycle all")
    print()
    print(f"  {CYAN}g{RESET}. open OpenRGB GUI  {YELLOW}(for per-LED precision control){RESET}")
    print(f"  {CYAN}q{RESET}. quit & lights off")
    print()
    return get_choice(patterns, names)

# ─── OpenRGB ──────────────────────────────────────────────────────────────────

def open_openrgb():
    running = subprocess.run(["pgrep", "-x", "openrgb"], capture_output=True).returncode == 0
    if running:
        warn("OpenRGB is already open — check your taskbar")
    else:
        subprocess.Popen([OPENRGB_BIN], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        ok("OpenRGB launched")

# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    print(f"\n{BOLD}fanlight{RESET} — Framework fan LED controller")

    patterns = discover_patterns()
    proc     = None
    current  = None

    def cleanup(sig=None, frame=None):
        stop_pattern(proc)
        print(f"\n{YELLOW}Lights off. Bye!{RESET}\n")
        sys.exit(0)

    signal.signal(signal.SIGINT,  cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    choice = main_menu(patterns)

    while True:
        if choice == "quit":
            stop_pattern(proc)
            print(f"\n{YELLOW}Lights off. Bye!{RESET}\n")
            break

        if choice == "gui":
            open_openrgb()
            choice = running_menu(patterns, current) if current else main_menu(patterns)
            continue

        # New pattern selected — only restart if it changed
        if choice != current:
            stop_pattern(proc)
            time.sleep(0.3)
            proc    = start_pattern(choice)
            current = choice

            # Give it a moment and check it didn't immediately crash
            time.sleep(0.5)
            if proc.poll() is not None:
                error = proc.stderr.read().decode().strip()
                err(f"Pattern failed to start: {error}")
                proc    = None
                current = None
                choice  = main_menu(patterns)
                continue

        choice = running_menu(patterns, current)

if __name__ == "__main__":
    main()
